# ===================================
# Joohwan Dev Blog 환경변수 설정
# ===================================

# Notion API 설정 (필수)
NOTION_API_KEY=your_notion_api_key_here
NOTION_DATABASE_ID=your_notion_database_id_here

# Notion 댓글 데이터베이스 설정 (필수)
NOTION_COMMENTS_DATABASE_ID=your_notion_comments_database_id_here

# Notion 반응 데이터베이스 설정 (필수)
NOTION_REACTIONS_DATABASE_ID=your_notion_reactions_database_id_here

# Notion 이벤트 데이터베이스 설정 (필수)
NOTION_EVENTS_DATABASE_ID=your_notion_events_database_id_here

# Notion 사용자 관련 설정 (필수)
NOTION_USERS_DATABASE_ID=your_users_database_id
NOTION_ACTIVITY_LOGS_DATABASE_ID=your_activity_logs_database_id
NOTION_USER_SESSIONS_DATABASE_ID=your_sessions_database_id
NOTION_USER_PERMISSIONS_DATABASE_ID=your_permissions_database_id
NOTION_USER_COMMENTS_DATABASE_ID=your_user_comments_database_id
NOTION_USER_REACTIONS_DATABASE_ID=your_user_reactions_database_id

# Notion 사이트 설정 데이터베이스 (필수)
NOTION_SITE_SETTINGS_DATABASE_ID=your_site_settings_database_id

# Notion 팝업 관리 데이터베이스 (필수)
NOTION_POPUP_DATABASE_ID=your_popup_database_id

# Notion 사용자 알림 설정 데이터베이스 (웹 알림용)
NOTION_USER_NOTIFICATIONS_DATABASE_ID=your_user_notifications_database_id

# 관리자 페이지 설정 (필수)
ADMIN_AUTH_CODE=your_admin_auth_code_here

# Firebase 설정 (웹 알림용)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your_vapid_key_here
FIREBASE_SERVER_KEY=your_firebase_server_key_here

# Firebase Admin SDK 설정 (서버 사이드 알림 전송용)
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Next.js 설정 (선택사항)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="Dev Blog"
NEXT_PUBLIC_SITE_DESCRIPTION="개발자의 기술 블로그입니다."

# 개발 환경 설정 (선택사항)
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1

# ===================================
# 설정 방법
# ===================================

# 1. 이 파일을 .env.local로 복사
# cp .env.example .env.local

# 2. .env.local 파일에서 실제 값으로 변경
# NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTION_SITE_SETTINGS_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 3. 사이트 설정 데이터베이스 설정
# - SITE_SETTINGS_DATABASE_SETUP.md 파일 참고
# - Notion에서 사이트 설정 데이터베이스 생성
# - 기본 설정 데이터 추가

# 4. .env.local은 .gitignore에 포함되어 있어 자동으로 커밋되지 않음